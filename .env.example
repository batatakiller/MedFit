# ── Supabase ──────────────────────────────────────────────────────────────
# Chave pública (anon) — pode ir ao navegador. NUNCA coloque a service role aqui.
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# Service role — APENAS servidor (API routes / Edge Functions). Não exponha no frontend.
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# ── IA (OpenRouter preferencial; Anthropic direto como fallback) ──────────
# Se OPENROUTER_API_KEY e ANTHROPIC_API_KEY estiverem vazios, o sistema usa
# o mock multiagente integrado (modo demonstração).
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# Fallback quando OpenRouter não está configurado.
MEDFIT_AI_MODEL=claude-opus-4-8

# Roteamento por agente via OpenRouter (sobrescreva se quiser trocar modelos).
MEDFIT_OPENROUTER_MODEL_DEFAULT=openai/gpt-5.4
MEDFIT_OPENROUTER_MODEL_BODY_VISION=google/gemini-3.5-flash
MEDFIT_OPENROUTER_MODEL_MEDICAL=openai/gpt-5.5
MEDFIT_OPENROUTER_MODEL_NUTRITION=openai/gpt-5.4
MEDFIT_OPENROUTER_MODEL_TRAINING=openai/gpt-5.4
MEDFIT_OPENROUTER_MODEL_DISCUSSION=anthropic/claude-sonnet-4.6
MEDFIT_OPENROUTER_MODEL_SAFETY=openai/gpt-5.5
MEDFIT_OPENROUTER_MODEL_SAFETY_REVIEW=anthropic/claude-opus-4.8
MEDFIT_OPENROUTER_MODEL_INTEGRATED=openai/gpt-5.5
MEDFIT_OPENROUTER_MODEL_DAILY=openai/gpt-5.4-mini

# ── Embeddings (RAG) ──────────────────────────────────────────────────────
# URL da Edge Function `embed` (Supabase.ai gte-small, vector 384 dims).
# Se vazio, vetorização fica desativada (documentos ainda são salvos).
MEDFIT_EMBED_FUNCTION_URL=

# ── Push notifications (estrutura) ────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
